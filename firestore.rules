rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: profile document
    match /users/{userId} {
      // Anyone can read any profile (needed for browse/matching)
      allow read: if true;
      // Only the authenticated owner can write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;

      // Teaching skills subcollection
      match /skills_teach/{skillId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Learning skills subcollection
      match /skills_learn/{skillId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
